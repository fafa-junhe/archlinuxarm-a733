post_install() {
  systemctl preset radxa-hdmi-toggle-once.service 2>/dev/null || true
  udevadm control --reload-rules 2>/dev/null || true
}

post_upgrade() {
  post_install
}

pre_remove() {
  systemctl --no-reload disable radxa-hdmi-toggle-once.service 2>/dev/null || true
}

post_remove() {
  udevadm control --reload-rules 2>/dev/null || true
}
